C102.8 15 102.1 15.5 101.4 15.8C100.7 16.1 99.9 16.3 98.9 16.3C98.1 16.3 97.3 16.2 96.6 15.9C96 15.6 95.4 15.1 94.8 14.5ZM94.7 9.9C94.7 11.1 95.1 12.1 95.9 13C96.7 13.8 97.7 14.3 98.8 14.3C99.9 14.3 100.9 13.9 101.7 13.1C102.5 12.3 102.9 11.3 102.9 10.1C102.9 8.9 102.5 7.9 101.7 7.1C100.9 6.3 99.9 5.8 98.8 5.8C97.7 5.8 96.7 6.2 95.9 7C95.1 7.8 94.7 8.7 94.7 9.9Z\" fill=\"#4F4F4F\"><\u002Fpath><path d=\"M0 11H2.4V16H0V11Z\" fill=\"#F25022\"><\u002Fpath><path d=\"M4.4 5.6H6.8V16H4.4V5.6Z\" fill=\"#FFB902\"><\u002Fpath><path d=\"M8.8 0H11.2V16H8.8V0Z\" fill=\"#80BA01\"><\u002Fpath><path d=\"M15.6 0H19.2V2.4H15.6V16H13.2V0H15.6Z\" fill=\"#19A0E5\"><\u002Fpath><\u002Fg><defs><clipPath id=\"wtlogo\"><rect width=\"106\" height=\"20\" fill=\"white\"><\u002Frect><\u002FclipPath><\u002Fdefs><\u002Fsvg>';\n\n  function chrome(section, num) {\n    // edge strip (skip if a manual one is already present)\n    if (!section.querySelector('.edge-strip')) {\n      var strip = document.createElement('div');\n      strip.className = 'edge-strip';\n      strip.innerHTML = '<div class=\"seg orange\"><\u002Fdiv><div class=\"seg yellow\"><\u002Fdiv><div class=\"seg green\"><\u002Fdiv><div class=\"seg blue\"><\u002Fdiv>';\n      section.insertBefore(strip, section.firstChild);\n    }\n    // corner logo (content slides only)\n    if (section.classList.contains('content') && !section.querySelector('.slide-corner-logo')) {\n      var cl = document.createElement('div');\n      cl.className = 'slide-corner-logo';\n      cl.innerHTML = LOGO;\n      section.appendChild(cl);\n    }\n    // slide-foot (content slides only)\n    if (section.classList.contains('content') && !section.querySelector('.slide-foot')) {\n      var foot = document.createElement('div');\n      foot.className = 'slide-foot';\n      var label = section.getAttribute('data-foot') || '';\n      foot.innerHTML = '<div class=\"brand\"><div class=\"foot-logo\">' + LOGO + '<\u002Fdiv><span>WhaTap NMS · ' + num + ' / 25<\u002Fspan><\u002Fdiv><div>' + label + '<\u002Fdiv>';\n      section.appendChild(foot);\n    }\n  }\n\n  function arrows() {\n    var svg = '<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M4 12h15M13 6l6 6-6 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><\u002Fsvg>';\n    document.querySelectorAll('[data-arrow]').forEach(function (a) { if (!a.innerHTML.trim()) a.innerHTML = svg; });\n  }\n\n  function logos() {\n    document.querySelectorAll('[data-logo]').forEach(function (el) { if (!el.innerHTML.trim()) el.innerHTML = LOGO; });\n  }\n\n  function run() {\n    var sections = document.querySelectorAll('deck-stage > section');\n    sections.forEach(function (s, i) {\n      if (s.classList.contains('content') || s.classList.contains('section-slide')) {\n        chrome(s, String(i + 1).padStart(2, '0'));\n      }\n    });\n    logos();\n    arrows();\n  }\n\n  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);\n  else run();\n})();\n<\u002Fscript>\n\n<script src=\"f69c2d1e-f651-423c-863b-a045729704d5\"><\u002Fscript>\n\n\n\n<\u002Fbody><\u002Fhtml>"
