 position: relative;\n  overflow: hidden;\n}\n\n.card.accent-top { border-top: 3px solid var(--accent); }\n\n.card .card-eyebrow {\n  font-family: var(--font-mono);\n  font-size: 18px;\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  color: var(--text-faint);\n  font-weight: 500;\n}\n\n.card .card-eyebrow.tint-accent { color: var(--accent); }\n.card .card-eyebrow.tint-blue { color: var(--blue); }\n.card .card-eyebrow.tint-orange { color: var(--orange); }\n.card .card-eyebrow.tint-purple { color: var(--purple); }\n\n.card h3 {\n  font-family: var(--font-display);\n  font-size: 40px;\n  font-weight: 600;\n  letter-spacing: -0.025em;\n  color: var(--text);\n  line-height: 1.05;\n}\n\n.card .card-sub {\n  font-size: 22px;\n  color: var(--text-dim);\n  line-height: 1.4;\n  margin-top: -8px;\n}\n\n.card p {\n  font-size: 22px;\n  color: var(--text-dim);\n  line-height: 1.45;\n}\n\n.card .card-divider {\n  height: 1px;\n  background: var(--border-soft);\n  margin: 4px 0;\n}\n\n.card .card-list {\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n  margin-top: 6px;\n  width: 100%;\n  padding-left: 0;\n}\n\n.card .card-list li {\n  list-style: none;\n  font-size: 21px;\n  color: var(--text-dim);\n  line-height: 1.4;\n  position: relative;\n  padding-left: 22px;\n  display: block;\n  width: 100%;\n}\n\n.card .card-list li::before {\n  content: \"\";\n  position: absolute;\n  left: 0;\n  top: 12px;\n  width: 8px;\n  height: 8px;\n  border-radius: 999px;\n  background: var(--accent);\n  display: block;\n}\n\n.card .card-list.tint-blue li::before { background: var(--blue); }\n.card .card-list.tint-orange li::before { background: var(--orange); }\n.card .card-list.tint-purple li::before { background: var(--purple); }\n\n.card .card-footer {\n  margin-top: auto;\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-end;\n  padding-top: 16px;\n  border-top: 1px solid var(--border-soft);\n}\n\n.card .card-footer .footer-label {\n  font-family: var(--font-mono);\n  font-size: 16px;\n  letter-spacing: 0.15em;\n  color: var(--text-faint);\n  text-transform: uppercase;\n}\n\n.card .card-footer .footer-value {\n  font-family: var(--font-display);\n  font-size: 36px;\n  font-weight: 700;\n  color: var(--accent);\n}\n\n/* ============================================================\n   BIG NUMBER cards (for \"Three guarantees\")\n   ============================================================ */\n\n.numbered-list {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n  margin-top: var(--gap-title);\n  flex: 1;\n}\n\n.numbered-item {\n  background: var(--surface);\n  border: 1px solid var(--border-soft);\n  border-radius: 18px;\n  padding: 26px 44px;\n  display: grid;\n  grid-template-columns: 140px 1fr auto;\n  gap: 36px;\n  align-items: center;\n  min-height: 0;\n}\n\n.numbered-item .big-num {\n  font-family: var(--font-display);\n  font-size: 92px;\n  font-weight: 700;\n  line-height: 1;\n  color: var(--accent);\n  letter-spacing: -0.04em;\n  border-right: 2px solid var(--border-soft);\n  padding-right: 28px;\n  text-align: center;\n}\n\n.numbered-item .item-body { display: flex; flex-direction: column; gap: 10px; }\n\n.numbered-item .item-eyebrow {\n  font-family: var(--font-mono);\n  font-size: 18px;\n  letter-spacing: 0.18em;\n  color: var(--text-faint);\n  text-transform: uppercase;\n}\n\n.numbered-item .item-title {\n  font-family: var(--font-display);\n  font-size: 38px;\n  font-weight: 600;\n  color: var(--text);\n  letter-spacing: -0.015em;\n}\n\n.numbered-item .item-desc {\n  font-size: 22px;\n  color: var(--text-dim);\n  line-height: 1.4;\n}\n\n.numbered-item .item-tag {\n  font-family: var(--font-mono);\n  font-size: 16px;\n  letter-spacing: 0.15em;\n  color: var(--accent);\n  text-transform: uppercase;\n  text-align: right;\n  white-space: nowrap;\n}\n\n/* ============================================================\n   LAYER STACK (Two-layer model)\n   ============================================================ */\n\n.layer-stack {\n  display: flex;\n  flex-direction: column;\n  gap: 18px;\n  margin-top: var(--gap-title);\n  flex: 1;\n  min-height: 0;\n}\n\n.layer-row {\n  background: var(--surface);\n  border: 1px solid var(--border-soft);\n  border-left: 4px solid var(--accent);\n  border-radius: 14px;\n  padding: 24px 36px;\n  display: grid;\n  grid-template-columns: 280px 1fr 460px;\n  gap: 36px;\n  align-items: center;\n  min-height: 0;\n}\n\n.layer-row.tint-blue { border-left-color: var(--blue); }\n.layer-row.tint-orange { border-left-color: var(--orange); }\n\n.layer-row .layer-label {\n  font-family: var(--font-mono);\n  font-size: 18px;\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  color: var(--accent);\n  font-weight: 500;\n}\n\n.layer-row.tint-blue .layer-label { color: var(--blue); }\n.layer-row.tint-orange .layer-label { color: var(--orange); }\n\n.layer-row .layer-title {\n  font-family: var(--font-display);\n  font-size: 30px;\n  font-weight: 600;\n  color: var(--text);\n  letter-spacing: -0.015em;\n  margin-top: 4px;\n  line-height: 1.1;\n}\n\n.layer-row .layer-desc {\n  font-size: 19px;\n  color: var(--text-dim);\n  line-height: 1.4;\n}\n\n.layer-row .layer-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  justify-content: flex-end;\n}\n\n.layer-row .tag-pill {\n  font-family: var(--font-mono);\n  font-size: 15px;\n  letter-spacing: 0.08em;\n  background: var(--surface-2);\n  color: var(--text);\n  padding: 9px 16px;\n  border-radius: 8px;\n  border: 1px solid var(--border-soft);\n  white-space: nowrap;\n}\n\n/* ============================================================\n   FLOW DIAGRAM (MCP data flow)\n   ============================================================ */\n\n.flow {\n  display: grid;\n  grid-template-columns: 1fr 60px 1fr 60px 1fr;\n  gap: 0;\n  align-items: stretch;\n  margin-top: var(--gap-title);\n  flex: 1;\n}\n\n.flow-step {\n  background: var(--surface);\n  border: 1px solid var(--border