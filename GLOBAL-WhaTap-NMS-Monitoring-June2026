rmat('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"c1b2a118-1ba5-4b52-9fdc-332678afafcb\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"bd38a29e-5d9e-466d-bd27-33a39f323d34\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"a4233042-6763-45d3-bdfe-d5fbcde9b0dc\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>/* ============================================================\n   WhaTap AI Overview Deck\n   ============================================================ */\n\n:root {\n  /* Type scale (1920x1080) */\n  --type-display: 96px;\n  --type-title: 64px;\n  --type-subtitle: 44px;\n  --type-body: 30px;\n  --type-small: 24px;\n  --type-eyebrow: 22px;\n  --type-mega: 220px;\n\n  /* Spacing */\n  --pad-x: 110px;\n  --pad-top: 100px;\n  --pad-bottom: 90px;\n  --gap-title: 56px;\n  --gap-item: 32px;\n\n  /* Color — LIGHT default (matches WhaTap PPTX template) */\n  --bg: #F8FAFC;\n  --bg-tint: #FFFFFF;\n  --surface: #FFFFFF;\n  --surface-2: #F1F5F9;\n  --border: #E2E8F0;\n  --border-soft: #EDF1F7;\n\n  --text: #0F172A;       /* slate-900 */\n  --text-dim: #475569;   /* slate-600 */\n  --text-faint: #94A3B8; /* slate-400 */\n\n  /* Brand — WhaTap blue */\n  --accent: #296CF2;\n  --accent-2: #3B82F6;\n  --accent-bright: #3B82F6;\n  --accent-soft: rgba(41, 108, 242, 0.10);\n  --accent-strong: rgba(41, 108, 242, 0.20);\n  --brand-gradient: linear-gradient(135deg, #296CF2 0%, #3B82F6 100%);\n\n  /* WhaTap logo bar palette */\n  --bar-orange: #FF6B35;\n  --bar-yellow: #FFC107;\n  --bar-green:  #8BC34A;\n  --bar-blue:   #2196F3;\n\n  --blue: #296CF2;\n  --green: #16A34A;\n  --orange: #EA580C;\n  --purple: #7C3AED;\n  --red: #DC2626;\n\n  /* Fonts */\n  --font-display: 'Space Grotesk', system-ui, sans-serif;\n  --font-body: 'Manrope', system-ui, sans-serif;\n  --font-mono: 'JetBrains Mono', ui-monospace, monospace;\n}\n\n/* Dark theme override */\n:root[data-theme=\"dark\"] {\n  --bg: #0a0d12;\n  --bg-tint: #0e131c;\n  --surface: #141a25;\n  --surface-2: #1a2231;\n  --border: #2a3344;\n  --border-soft: #1f2735;\n  --text: #f4f6fa;\n  --text-dim: #aab3c2;\n  --text-faint: #6c7686;\n  --accent: #3B82F6;\n  --accent-bright: #6FA0FF;\n  --accent-soft: rgba(59, 130, 246, 0.14);\n  --accent-strong: rgba(59, 130, 246, 0.28);\n}\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nhtml, body {\n  background: #000;\n  color: var(--text);\n  font-family: var(--font-body);\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility;\n}\n\ndeck-stage {\n  background: #000;\n  font-family: var(--font-body);\n}\n\ndeck-stage section {\n  background: var(--bg);\n  color: var(--text);\n  font-family: var(--font-body);\n  font-size: var(--type-body);\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  position: relative;\n}\n\n/* Left-edge 4-color WhaTap brand strip on every slide \\u2014 PPTX-friendly */\n.edge-strip {\n  position: absolute;\n  left: 0;\n  top: 0;\n  bottom: 0;\n  width: 16px;\n  display: flex;\n  flex-direction: column;\n  z-index: 2;\n  pointer-events: none;\n}\n.edge-strip .seg { flex: 1; }\n.edge-strip .seg.orange { background: var(--bar-orange); }\n.edge-strip .seg.yellow { background: var(--bar-yellow); }\n.edge-strip .seg.green  { background: var(--bar-green); }\n.edge-strip .seg.blue   { background: var(--bar-blue); }\n\n/* Top-right WhaTap logo badge on every slide (except title) */\n.slide-corner-logo {\n  position: absolute;\n  top: 56px;\n  right: 70px;\n  height: 30px;\n  display: flex;\n  align-items: center;\n  color: var(--text);\n  z-index: 3;\n  pointer-events: none;\n}\n.slide-corner-logo svg { height: 100%; width: auto; display: block; }\n/* Wordmark paths default to #4F4F4F in browser \\u2014 force currentColor; bars keep theirs */\n.slide-corner-logo svg path[fill=\"#4F4F4F\"],\n.slide-corner-logo svg path:not([fill]) { fill: currentColor; }\n\n/* Same treatment for the title-slide big logo and slide-foot small logo */\n.title-slide .logo-mark svg path[fill=\"#4F4F4F\"],\n.title-slide .logo-mark svg path:not([fill]) { fill: currentColor; }\n.foot-logo svg path[fill=\"#4F4F4F\"],\n.foot-logo svg path:not([fill]) { fill: currentColor; }\n\n/* 4-bar accent decoration shown above titles on content slides */\n.bar-accent {\n  display: inline-flex;\n  gap: 5px;\n  height: 6px;\n  margin-bottom: 28px;\n  align-items: flex-end;\n}\n.bar-accent .seg {\n  width: 30px;\n  height: 100%;\n  border-radius: 2px;\n}\n.bar-accent .seg.s1 { background: var(--bar-orange); }\n.bar-accent .seg.s2 { background: var(--bar-yellow); }\n.bar-accent .seg.s3 { background: var(--bar-green); }\n.bar-accent .seg.s4 { background: var(--bar-blue); }\n\n/* ============================================================\n   Common atoms\n   ============================================================ */\n\n.slide-pad {\n  padding: var(--pad-top) var(--pad-x) var(--pad-bottom);\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  padding-left: calc(var(--pad-x) + 16px);\n}\n\n.eyebrow {\n  font-family: var(--font-mono);\n  font-size: var(--type-eyebrow);\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n  color: var(--accent);\n  font-weight: 500;\n}\n\n.slide-title {\n  font-family: var(--font-display);\n  font-size: var(--type-title);\n  font-weight: 600;\n  letter-spacing: -0.02em;\n  line-height: 1.06;\n  color: var(--text);\n  text-wrap: pretty;\n  max-width: 1500px;\n}\n\n.slide-title .accent { color: var(--accent); }\n\n.slide-subtitle {\n  font-family: var(--font-body);\n  font-size: var(--type-subtitle);\n  font-weight: 400;\n  line-height: 1.25;\n  color: var(--text-dim);\n  text-wrap: pretty;\n  max-width: 1400px;\n}\n\n.slide-foot {\n  position: absolute;\n  bottom: 32px;\n  left: var(--pad-x);\n  right: var(--pad-x);\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-family: var(--font-mono);\n  font-size: 16px;\n  letter-spacing: 0.14em;\n  color: var(--text-faint);\n  white-space: nowrap;\n}\n\n.slide-foot > * { white-space: nowrap; }\n\n.slide-foot .brand {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  white-space: nowrap;\n}\n\n.slide-foot .dot { display: none; }\n\n.slide-foot .dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 999px;\n  background: var(--brand-gradient);\n}\n\n/* ============================================================\n   TITLE SLIDE\n   ============================================================ */\n\n.title-slide {\n  background:\n    radial-gradient(ellipse 80% 60% at 100% 100%, rgba(41, 108, 242, 0.06) 0%, transparent 65%),\n    radial-gradient(ellipse 60% 40% at 0% 0%, rgba(59, 130, 246, 0.04) 0%, transparent 60%),\n    var(--bg);\n  justify-content: space-between;\n}\n\n.title-slide .top-bar {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 60px var(--pad-x) 0;\n}\n\n.title-slide .logo {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  color: var(--text);\n}\n\n.title-slide .logo .ai-suffix {\n  font-family: var(--font-display);\n  font-weight: 500;\n  font-size: 28px;\n  color: var(--text-faint);\n  letter-spacing: -0.01em;\n  padding-left: 4px;\n  border-left: 1px solid var(--border);\n  margin-left: 2px;\n}\n\n.title-slide .logo-mark {\n  display: inline-flex;\n  align-items: center;\n  height: 40px;\n}\n.title-slide .logo-mark svg {\n  height: 100%;\n  width: auto;\n  display: block;\n}\n\n/* Small logo for slide-foot — used on every non-title slide */\n.foot-logo {\n  display: inline-flex;\n  align-items: center;\n  height: 18px;\n  margin-right: 4px;\n}\n.foot-logo svg {\n  height: 100%;\n  width: auto;\n  display: block;\n}\n\n.title-slide .tag {\n  font-family: var(--font-mono);\n  font-size: 18px;\n  letter-spacing: 0.16em;\n  color: var(--text-faint);\n  text-transform: uppercase;\n  white-space: nowrap;\n}\n\n.title-slide .center {\n  padding: 0 var(--pad-x);\n  display: flex;\n  flex-direction: column;\n  gap: 48px;\n  max-width: 1600px;\n}\n\n.title-slide h1 {\n  font-family: var(--font-display);\n  font-size: var(--type-display);\n  font-weight: 700;\n  line-height: 0.98;\n  letter-spacing: -0.035em;\n  color: var(--text);\n}\n\n.title-slide h1 .for {\n  color: var(--text-faint);\n  font-weight: 400;\n}\n\n.title-slide h1 .ai {\n  color: var(--accent);\n}\n\n.title-slide .triplet {\n  display: flex;\n  gap: 56px;\n  font-family: var(--font-display);\n  font-size: 40px;\n  font-weight: 500;\n  color: var(--text-dim);\n}\n.title-slide .triplet span b { color: var(--text); font-weight: 600; }\n\n.title-slide .scenarios {\n  font-family: var(--font-body);\n  font-size: var(--type-subtitle);\n  color: var(--text-dim);\n  max-width: 1100px;\n  line-height: 1.3;\n}\n\n.title-slide .bottom-bar {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-end;\n  padding: 0 var(--pad-x) 60px;\n  font-family: var(--font-mono);\n  font-size: 22px;\n  color: var(--text-faint);\n  letter-spacing: 0.08em;\n}\n.title-slide .bottom-bar .who {\n  color: var(--text);\n  font-family: var(--font-display);\n  font-size: 28px;\n  font-weight: 500;\n  letter-spacing: -0.005em;\n}\n.title-slide .bottom-bar .role {\n  color: var(--text-faint);\n  font-family: var(--font-mono);\n  font-size: 18px;\n  letter-spacing: 0.16em;\n  text-transform: uppercase;\n  margin-top: 8px;\n}\n\n/* ============================================================\n   SECTION HEADER SLIDE\n   ============================================================ */\n\n.section-slide {\n  background:\n    radial-gradient(ellipse 70% 50% at 100% 50%, var(--accent-soft) 0%, transparent 65%),\n    var(--bg);\n}\n\n.section-slide .slide-pad {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 80px;\n  align-items: center;\n}\n\n.section-slide .left {\n  display: flex;\n  flex-direction: column;\n  gap: 40px;\n}\n\n.section-slide .section-num {\n  font-family: var(--font-display);\n  font-size: 260px;\n  font-weight: 700;\n  line-height: 0.85;\n  letter-spacing: -0.05em;\n  color: var(--accent);\n}\n\n.section-slide .section-num .slash {\n  color: var(--text-faint);\n  font-weight: 400;\n}\n\n.section-slide .section-label {\n  font-family: var(--font-mono);\n  font-size: 22px;\n  letter-spacing: 0.22em;\n  color: var(--text-faint);\n  text-transform: uppercase;\n}\n\n.section-slide h2 {\n  font-family: var(--font-display);\n  font-size: 100px;\n  font-weight: 700;\n  letter-spacing: -0.035em;\n  line-height: 0.98;\n  color: var(--text);\n}\n\n.section-slide .desc {\n  font-size: var(--type-subtitle);\n  color: var(--text-dim);\n  line-height: 1.3;\n  max-width: 700px;\n}\n\n.section-slide .topics {\n  margin-top: 24px;\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n  border-left: 2px solid var(--accent);\n  padding-left: 32px;\n}\n\n.section-slide .topic {\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n}\n\n.section-slide .topic-num {\n  font-family: var(--font-mono);\n  font-size: 18px;\n  letter-spacing: 0.18em;\n  color: var(--text-faint);\n  text-transform: uppercase;\n}\n\n.section-slide .topic-title {\n  font-family: var(--font-display);\n  font-size: 38px;\n  font-weight: 500;\n  color: var(--text);\n  letter-spacing: -0.01em;\n}\n\n/* Section-header slides: per-section accent color */\n.section-slide[data-accent=\"orange\"] { --sec-accent: var(--bar-orange); }\n.section-slide[data-accent=\"yellow\"] { --sec-accent: #D97706; }\n.section-slide[data-accent=\"green\"]  { --sec-accent: var(--bar-green); }\n.section-slide[data-accent=\"blue\"]   { --sec-accent: var(--bar-blue); }\n.section-slide[data-accent=\"blue-strong\"] { --sec-accent: var(--accent); }\n\n.section-slide[data-accent] .section-num {\n  color: var(--sec-accent);\n}\n.section-slide[data-accent] .section-label,\n.section-slide[data-accent] .topic-num {\n  color: var(--sec-accent);\n}\n.section-slide[data-accent] .topics {\n  border-left-color: var(--sec-accent);\n}\n\n.section-slide .chapter-tag {\n  display: none;\n}\n\n/* ============================================================\n   FEATURE SLIDE (split: text left, screenshot right)\n   ============================================================ */\n\n.feature-slide .slide-pad {\n  display: grid;\n  grid-template-columns: 620px 1fr;\n  gap: 72px;\n  align-items: stretch;\n}\n\n.feature-slide .feat-left {\n  display: flex;\n  flex-direction: column;\n  gap: 32px;\n}\n\n.feature-slide .feat-eyebrow {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  font-family: var(--font-mono);\n  font-size: 22px;\n  letter-spacing: 0.18em;\n  color: var(--feat-accent, var(--accent));\n  text-transform: uppercase;\n  font-weight: 500;\n  flex-wrap: wrap;\n}\n\n.feature-slide .feat-eyebrow > * { white-space: nowrap; }\n\n.feature-slide .feat-eyebrow .num {\n  font-family: var(--font-display);\n  font-size: 32px;\n  color: var(--feat-accent, var(--accent));\n  font-weight: 600;\n  letter-spacing: 0;\n}\n\n.feature-slide .feat-eyebrow .pill {\n  font-family: var(--font-mono);\n  font-size: 16px;\n  background: color-mix(in oklab, var(--feat-accent, var(--accent)) 12%, transparent);\n  color: var(--feat-accent, var(--accent));\n  padding: 6px 12px;\n  border-radius: 999px;\n  letter-spacing: 0.12em;\n}\n\n.feature-slide .bullet .marker {\n  width: 12px;\n  height: 12px;\n  border-radius: 3px;\n  background: var(--feat-accent, var(--accent));\n  margin-top: 14px;\n}\n\n/* Per-feature accent color rotation — cycle through 4 WhaTap brand colors */\n.feature-slide[data-accent=\"orange\"] { --feat-accent: var(--bar-orange); }\n.feature-slide[data-accent=\"yellow\"] { --feat-accent: #D97706; }\n.feature-slide[data-accent=\"green\"]  { --feat-accent: var(--bar-green); }\n.feature-slide[data-accent=\"blue\"]   { --feat-accent: var(--bar-blue); }\n.feature-slide[data-accent=\"blue-strong\"] { --feat-accent: var(--accent); }\n\n.feature-slide h2 {\n  font-family: var(--font-display);\n  font-size: 56px;\n  font-weight: 600;\n  line-height: 1.05;\n  letter-spacing: -0.025em;\n  color: var(--text);\n  text-wrap: pretty;\n}\n\n.feature-slide .feat-summary {\n  font-size: 26px;\n  color: var(--text-dim);\n  line-height: 1.4;\n  max-width: 580px;\n}\n\n.feature-slide .bullets {\n  display: flex;\n  flex-direction: column;\n  gap: 26px;\n  margin-top: 8px;\n}\n\n.feature-slide .bullet {\n  display: grid;\n  grid-template-columns: 30px 1fr;\n  gap: 18px;\n  align-items: start;\n}\n\n.feature-slide .bullet h3 {\n  font-family: var(--font-display);\n  font-size: 26px;\n  font-weight: 600;\n  color: var(--text);\n  letter-spacing: -0.01em;\n  line-height: 1.2;\n  margin-bottom: 6px;\n}\n\n.feature-slide .bullet p {\n  font-size: 21px;\n  color: var(--text-dim);\n  line-height: 1.4;\n}\n\n.feature-slide .feat-right {\n  background: var(--surface);\n  border: 1px solid var(--border-soft);\n  border-radius: 16px;\n  overflow: hidden;\n  display